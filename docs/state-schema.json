{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Workflow State",
  "description": "Schema for .workflow/state.json",
  "type": "object",
  "required": ["task_id", "started_at", "current_step", "total_runs", "total_tokens", "estimated_cost", "agents", "defects", "history"],
  "properties": {
    "task_id": {
      "type": "string",
      "description": "Unique task identifier"
    },
    "started_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when task started"
    },
    "completed_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "ISO 8601 timestamp when task completed"
    },
    "current_step": {
      "type": "string",
      "enum": [
        "validate_input",
        "analyze",
        "split",
        "mcp_search",
        "test_documentation",
        "develop",
        "code_review",
        "security_check",
        "test_code",
        "fix_defects",
        "document",
        "demo",
        "complete"
      ],
      "description": "Current workflow step"
    },
    "total_runs": {
      "type": "integer",
      "minimum": 0,
      "description": "Total number of agent runs"
    },
    "total_tokens": {
      "type": "integer",
      "minimum": 0,
      "description": "Total tokens used across all agents"
    },
    "estimated_cost": {
      "type": "number",
      "minimum": 0,
      "description": "Estimated cost in USD"
    },
    "agents": {
      "type": "object",
      "properties": {
        "analyst": { "$ref": "#/definitions/agentState" },
        "developer": { "$ref": "#/definitions/agentState" },
        "tester": { "$ref": "#/definitions/agentState" },
        "security": { "$ref": "#/definitions/agentState" }
      },
      "additionalProperties": false
    },
    "defects": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of defect IDs"
    },
    "history": {
      "type": "array",
      "items": { "$ref": "#/definitions/historyEntry" },
      "description": "Execution history"
    }
  },
  "definitions": {
    "agentState": {
      "type": "object",
      "required": ["runs", "tokens", "status"],
      "properties": {
        "runs": {
          "type": "integer",
          "minimum": 0
        },
        "tokens": {
          "type": "integer",
          "minimum": 0
        },
        "status": {
          "type": "string",
          "enum": ["pending", "in_progress", "completed", "failed"]
        }
      }
    },
    "historyEntry": {
      "type": "object",
      "required": ["step", "timestamp", "result"],
      "properties": {
        "step": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "result": {
          "type": "string"
        }
      }
    }
  }
}
