        <mxCell id="diff_title" value="📝 CHANGES vs architecture-map.drawio / Отличия от предыдущей схемы" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=14;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="70" y="1165" width="450" height="25" as="geometry" />
        </mxCell>
        <mxCell id="diff_text" value="• OLD: 9-step workflow (Prompt → Spec → Observe → Orient → Decide → Act → Judge → Memory → Loop)&#xa;    NEW: 12-step workflow (Prompt → Spec → Validate → Analyst → Review → Developer → Run Tests → Test → Security → Done → Questions → Error)&#xa;• OLD: 4 OODA agents (observe, orient, decide, act) — no contracts&#xa;    NEW: 4 subagents (analyst, developer, tester, security) — with unified contracts + self-validation checklists&#xa;• NEW: Task type pipelines (feature/bug/refactor/docs) define which steps to skip&#xa;• NEW: src/agent_contract.py provides programmatic validation&#xa;• NEW: Security agent mandatory for auth/password/encryption changes" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="70" y="1190" width="1540" height="65" as="geometry" />
        </mxCell>

